{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/.next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/index.py"
    }
  ],
  "env": {
    "NEXT_PUBLIC_BACKEND_URL": "https://ai-poster-studio.vercel.app"
  }
}
