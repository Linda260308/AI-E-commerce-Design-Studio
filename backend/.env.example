# Qwen API (阿里云 DashScope)
QWEN_API_KEY=sk-46c536ffaf7140679d76a35016d9a488

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/ai_poster_studio

# Redis 配置
REDIS_URL=redis://localhost:6379

# 云存储配置 (CloudFlare R2)
R2_BUCKET_NAME=ai-poster-storage
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# PayPal 配置
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox  # sandbox 或 production

# JWT 认证
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION_DAYS=30

# 应用配置
APP_ENV=development  # development 或 production
DEBUG=True
API_PREFIX=/api
FRONTEND_URL=http://localhost:3000
